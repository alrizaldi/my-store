generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  @@map("roles")
}

model User {
  id         String           @id @default(cuid())
  name       String
  email      String           @unique
  password   String
  phone      String?
  avatar     String?
  isActive   Boolean          @default(true)
  roleId     String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  attendance Attendance[]
  sessions   CashierSession[]
  orders     Order[]
  role       Role             @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

model Product {
  id             String              @id @default(cuid())
  name           String
  description    String?
  price          Float
  stock          Int                 @default(0)
  imageUrl       String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  categoryId     String?
  cost           Float               @default(0)
  isActive       Boolean             @default(true)
  minStock       Int                 @default(5)
  sku            String              @unique
  orderItems     OrderItem[]
  category       Category?           @relation(fields: [categoryId], references: [id])
  promoProducts  PromoProduct[]
  purchaseItems  PurchaseOrderItem[]
  stockMovements StockMovement[]

  @@map("products")
}

model StockMovement {
  id          String            @id @default(cuid())
  type        StockMovementType
  quantity    Int
  notes       String?
  productId   String
  referenceId String?
  createdAt   DateTime          @default(now())
  product     Product           @relation(fields: [productId], references: [id])

  @@map("stock_movements")
}

model Order {
  id          String          @id @default(cuid())
  status      OrderStatus     @default(PENDING)
  total       Float
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  cashierId   String?
  discount    Float           @default(0)
  notes       String?
  orderNumber String          @unique
  promoId     String?
  sessionId   String?
  subtotal    Float
  tax         Float           @default(0)
  items       OrderItem[]
  cashier     User?           @relation(fields: [cashierId], references: [id])
  promo       Promo?          @relation(fields: [promoId], references: [id])
  session     CashierSession? @relation(fields: [sessionId], references: [id])
  payments    Payment[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  productId String
  orderId   String
  discount  Float   @default(0)
  subtotal  Float
  unitPrice Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Payment {
  id        String        @id @default(cuid())
  method    PaymentMethod
  amount    Float
  change    Float         @default(0)
  reference String?
  status    PaymentStatus @default(PENDING)
  orderId   String
  createdAt DateTime      @default(now())
  order     Order         @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model CashierSession {
  id        String        @id @default(cuid())
  cashierId String
  startCash Float
  endCash   Float?
  status    SessionStatus @default(OPEN)
  openedAt  DateTime      @default(now())
  closedAt  DateTime?
  cashier   User          @relation(fields: [cashierId], references: [id])
  orders    Order[]

  @@map("cashier_sessions")
}

model Supplier {
  id        String          @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  purchases PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id         String              @id @default(cuid())
  poNumber   String              @unique
  supplierId String
  status     PurchaseStatus      @default(PENDING)
  subtotal   Float
  tax        Float               @default(0)
  total      Float
  notes      String?
  orderedAt  DateTime            @default(now())
  receivedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  items      PurchaseOrderItem[]
  supplier   Supplier            @relation(fields: [supplierId], references: [id])

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  quantity        Int
  unitCost        Float
  subtotal        Float
  productId       String
  purchaseOrderId String
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_order_items")
}

model Promo {
  id          String         @id @default(cuid())
  name        String
  description String?
  code        String?        @unique
  type        PromoType
  value       Float
  minOrder    Float?
  maxDiscount Float?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  orders      Order[]
  products    PromoProduct[]

  @@map("promos")
}

model PromoProduct {
  id        String  @id @default(cuid())
  promoId   String
  productId String
  product   Product @relation(fields: [productId], references: [id])
  promo     Promo   @relation(fields: [promoId], references: [id])

  @@unique([promoId, productId])
  @@map("promo_products")
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  date      DateTime         @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("attendance")
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  QRIS
  TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum PurchaseStatus {
  PENDING
  ORDERED
  RECEIVED
  CANCELLED
}

enum PromoType {
  PERCENTAGE
  FIXED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  HOLIDAY
}
